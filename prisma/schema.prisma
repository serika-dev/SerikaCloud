generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String      @id @default(cuid())
  email             String      @unique
  name              String
  password          String
  emailVerified     Boolean     @default(false)
  verificationToken String?     @unique
  storageUsed       BigInt      @default(0)
  storageLimit      BigInt      @default(1073741824) // 1GB in bytes
  isAdmin           Boolean     @default(false)
  viewPreference    String      @default("grid")
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  files         File[]
  folders       Folder[]
  shareLinks    ShareLink[]
  documents     Document[]
  mailboxes     Mailbox[]
  presentations Presentation[]
}

model File {
  id        String   @id @default(cuid())
  name      String
  mimeType  String
  size      BigInt
  b2Key     String   @unique
  folderId  String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  folder     Folder?     @relation(fields: [folderId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  shareLinks ShareLink[]

  @@index([userId])
  @@index([folderId])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Folder?  @relation("FolderToFolder", fields: [parentId], references: [id], onDelete: Cascade)
  children Folder[] @relation("FolderToFolder")
  files    File[]
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([parentId])
}

model ShareLink {
  id            String    @id @default(cuid())
  shortId       String    @unique
  fileId        String
  userId        String
  expiresAt     DateTime?
  password      String?
  maxDownloads  Int?
  downloadCount Int       @default(0)
  createdAt     DateTime  @default(now())

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([shortId])
}

// ─── SerikaDocs ──────────────────────────────────────────────────────────────

model Document {
  id        String   @id @default(cuid())
  title     String   @default("Untitled Document")
  content   Json?
  userId    String
  shareId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── SerikaMail ──────────────────────────────────────────────────────────────

model Mailbox {
  id        String   @id @default(cuid())
  address   String   @unique
  userId    String
  isPrimary Boolean  @default(false)
  createdAt DateTime @default(now())

  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  aliases EmailAlias[]
  emails  Email[]
  folders MailFolder[]

  @@index([userId])
}

model EmailAlias {
  id        String   @id @default(cuid())
  address   String   @unique
  mailboxId String
  createdAt DateTime @default(now())

  mailbox Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)

  @@index([mailboxId])
}

model MailFolder {
  id        String @id @default(cuid())
  name      String
  type      String // inbox, sent, drafts, trash, spam, archive, custom
  icon      String @default("inbox")
  mailboxId String

  mailbox Mailbox @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  emails  Email[]

  @@unique([mailboxId, type])
  @@index([mailboxId])
}

model Email {
  id           String   @id @default(cuid())
  messageId    String?  @unique
  fromAddress  String
  fromName     String?
  toAddresses  Json
  ccAddresses  Json?
  bccAddresses Json?
  subject      String   @default("(No Subject)")
  bodyText     String?
  bodyHtml     String?
  mailboxId    String
  folderId     String
  isRead       Boolean  @default(false)
  isStarred    Boolean  @default(false)
  isDraft      Boolean  @default(false)
  headers      Json?
  inReplyTo    String?
  references   Json?
  createdAt    DateTime @default(now())
  receivedAt   DateTime @default(now())

  mailbox     Mailbox            @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  folder      MailFolder         @relation(fields: [folderId], references: [id], onDelete: Cascade)
  attachments EmailAttachment[]

  @@index([mailboxId])
  @@index([folderId])
  @@index([receivedAt])
}

model EmailAttachment {
  id         String @id @default(cuid())
  emailId    String
  filename   String
  mimeType   String
  size       BigInt
  storageKey String

  email Email @relation(fields: [emailId], references: [id], onDelete: Cascade)

  @@index([emailId])
}

// ─── SerikaPresent ───────────────────────────────────────────────────────────

model Presentation {
  id        String   @id @default(cuid())
  title     String   @default("Untitled Presentation")
  theme     String   @default("default")
  userId    String
  shareId   String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  slides Slide[]

  @@index([userId])
}

model Slide {
  id             String @id @default(cuid())
  presentationId String
  order          Int
  content        Json
  notes          String?
  layout         String @default("blank")
  background     String @default("#000000")

  presentation Presentation @relation(fields: [presentationId], references: [id], onDelete: Cascade)

  @@index([presentationId])
  @@index([presentationId, order])
}
